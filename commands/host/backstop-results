#!/bin/bash

#ddev-generated

## Description: Launch a browser with latest backstop results
## Usage: backstop-results
## Example: "ddev backstop-results"

# shellcheck source=../../.env.backstopjs
source .ddev/.env.backstopjs

case $OSTYPE in
  linux-gnu)
    xdg-open "${DDEV_APPROOT}/${BACKSTOPJS_TESTDIR}/backstop_data/html_report/index.html"
    ;;
  "darwin"*)
    open "${DDEV_APPROOT}/${BACKSTOPJS_TESTDIR}/backstop_data/html_report/index.html"
    ;;
  "win*"* | "msys"*)
    start "${DDEV_APPROOT}/${BACKSTOPJS_TESTDIR}/backstop_data/html_report/index.html"
    ;;
esac
